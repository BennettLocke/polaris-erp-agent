# sjagent 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===== Device / feature switches =====
# full = normal server; orangepi_desktop/lite = keep code synced but skip heavy local features.
SJAGENT_DEVICE_PROFILE=full
SJAGENT_LITE_MODE=0
SJAGENT_ENABLE_BAG_UPLOAD=1
BAG_UPLOAD_WORKERS=3
# Only controls the background hotword sync, not future speech recognition endpoints.
SJAGENT_ENABLE_ASR_HOTWORD_SCHEDULER=1

# ===== LLM =====
MIMO_API_KEY=your_mimo_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
MIMO_TTS_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2-tts
MIMO_TTS_VOICE=mimo_default

# ===== 飞书 =====
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# ===== ERP API =====
ERP_API_KEY=your_erp_api_key

# ===== MySQL =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sjerp
DB_USER=root
DB_PASSWORD=your_db_password

# ===== 北极星自有业务库（商品、客户、用户、订单、库存）=====
# 不填时，部分迁移脚本会回退使用上面的 DB_*；正式环境建议单独配置。
SJAGENT_CORE_DB_HOST=localhost
SJAGENT_CORE_DB_PORT=3306
SJAGENT_CORE_DB_NAME=sjagent_core
SJAGENT_CORE_DB_USER=sjagent_core
SJAGENT_CORE_DB_PASSWORD=your_sjagent_core_db_password
SJAGENT_DEFAULT_OPERATOR_USER_ID=
SJAGENT_DEFAULT_OPERATOR_USERNAME=

# ===== 微信小程序 =====
# 用于小程序微信快捷登录、手机号授权换取 openid / phone_info。
WECHAT_MINIAPP_APPID=wx_your_miniapp_appid
WECHAT_MINIAPP_SECRET=your_wechat_miniapp_secret

# 对账单 PDF 字体。默认优先使用 Windows 微软雅黑；
# 如果服务器没有微软雅黑，可填一个中文字体文件路径，避免 PDF 中文乱码。
SJAGENT_PDF_FONT_PATH=

# ===== 阿里云 OSS =====
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret

# ===== 阿里云智能语音交互 ASR =====
ALIYUN_AK_ID=your_aliyun_access_key_id
ALIYUN_AK_SECRET=your_aliyun_access_key_secret
ALIYUN_NLS_APPKEY=your_nls_project_appkey
# 可选：已有热词表 ID；不填则首次同步自动创建
ALIYUN_NLS_VOCAB_ID=
ALIYUN_ASR_MAX_HOTWORDS=500

# ===== 火山引擎 / 豆包 Realtime ASR =====
VOLC_ASR_API_KEY=your_volc_asr_api_key
VOLC_ASR_APP_KEY=
VOLC_ASR_ACCESS_KEY=
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
VOLC_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
VOLC_ASR_MODEL=bigmodel

# ===== 火山引擎 / 豆包流式 TTS =====
# 不填时会回退复用 VOLC_ASR_API_KEY；如果控制台要求独立 TTS Key，请填这里。
VOLC_TTS_API_KEY=
VOLC_TTS_RESOURCE_ID=seed-tts-2.0
VOLC_TTS_SPEAKER=zh_female_vv_uranus_bigtts
VOLC_TTS_FORMAT=mp3

# ===== 知识库 =====
# 默认用项目同级目录：\\SJBZ513\513sjbz\sjwiki 或服务器上的 /opt/sjwiki
SJAGENT_WIKI_PATH=../sjwiki

# ===== Web 后台会话 =====
# 本地开发建议 127.0.0.1；Docker/Nginx 反代环境设为 0.0.0.0。
SJAGENT_HTTP_HOST=127.0.0.1
# 生产环境必须填写高强度随机值，例如 32 字节以上随机字符串；不要使用示例值。
SJAGENT_SECRET_KEY=
# HTTPS/Nginx 反代生产环境建议开启；本地开发可留空。
SJAGENT_SESSION_COOKIE_SECURE=

# ===== 管理员查询 =====
# 只有输入：管理查询 <口令> <数据库名|数据库配置|知识库路径|智能体路径> 才会返回白名单内部信息
# 不会返回数据库密码、API Key、SSH 私钥等敏感密钥
SJAGENT_ADMIN_QUERY_TOKEN=change-this-token
